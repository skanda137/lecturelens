# LectureLens backend configuration

# Deepgram API key for audio transcription (https://console.deepgram.com)
DEEPGRAM_API_KEY=

# Groq API key for mind-map structuring (https://console.groq.com)
GROQ_API_KEY=

# Comma-separated list of origins allowed to call this API.
# Include your frontend's dev and production URLs.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# Path to the SQLite database file.
DB_PATH=./lecturelens.db

# When true, error responses include the raw exception message (dev only).
DEBUG=false
